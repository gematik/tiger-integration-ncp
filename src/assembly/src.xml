<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0 http://maven.apache.org/xsd/assembly-2.2.0.xsd">
  <id>reports</id>
  <formats>
    <format>zip</format>
  </formats>
  <includeBaseDirectory>false</includeBaseDirectory>
  <fileSets>
    <fileSet>
      <directory>logs</directory>
      <outputDirectory>/logs</outputDirectory>
      <includes>
        <include>tiger-integration-ncp.log</include>
      </includes>
    </fileSet>
    <fileSet>
      <directory>${project.build.directory}/serverLogs</directory>
      <outputDirectory>/serverLogs</outputDirectory>
      <includes>
        <include>**/*</include>
      </includes>
    </fileSet>
    <fileSet>
      <directory>${project.build.directory}/site/serenity</directory>
      <outputDirectory>/site/serenity</outputDirectory>
      <includes>
        <include>**/*</include>
      </includes>
    </fileSet>
    <fileSet>
      <directory>${project.build.directory}/generated-not-in-jar</directory>
      <outputDirectory>/generated-not-in-jar</outputDirectory>
      <includes>
        <include>**/*</include>
      </includes>
    </fileSet>
    <fileSet>
      <directory>${project.build.directory}/failsafe-reports</directory>
      <outputDirectory>/failsafe-reports</outputDirectory>
      <includes>
        <include>**/*</include>
      </includes>
    </fileSet>
    <fileSet>
      <directory>${project.build.directory}/externalJars</directory>
      <outputDirectory>/externalJars</outputDirectory>
      <includes>
        <include>application-ncp.yaml</include>
      </includes>
    </fileSet>
    <fileSet>
      <directory>${project.build.directory}/cucumber-parallel</directory>
      <outputDirectory>/cucumber-parallel</outputDirectory>
      <includes>
        <include>**/*</include>
      </includes>
    </fileSet>
    <fileSet>
      <directory>${project.build.directory}</directory>
      <outputDirectory>/</outputDirectory>
      <includes>
        <include>maven-javadoc-plugin-stale-data.txt</include>
      </includes>
    </fileSet>
  </fileSets>
</assembly>